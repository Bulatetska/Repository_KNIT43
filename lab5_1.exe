using System;
  class TimBoniuklab5_1{
    //мій варіант - 14
    public static void Main()
    {
      int M;  
      float I;   
      double T;  
      bool A;  
      string N_name; 
      Console.WriteLine("Введіть ім'я: "); 
      N_name = Console.ReadLine(); 
      Console.WriteLine("Введіть T");
      M = Convert.ToInt32(Console.ReadLine()); 
      Console.WriteLine("Введіть I");
      I = Convert.ToSingle(Console.ReadLine()); 
      Console.WriteLine("Введіть M");
      T = Convert.ToDouble(Console.ReadLine()); 
      Console.WriteLine("Введіть A");
      A = Convert.ToBoolean(Console.ReadLine());
      System.Console.WriteLine(" Результат: \n Ім'я = {0, 6}, A = {1, 4}", N_name,A);
      System.Console.WriteLine("T ={0, 4}, I = {1,10:f5}, M = {2,20:e8}", M,I,T);
      System.Console.WriteLine(" "); 
      System.Console.ReadLine();
    }
}